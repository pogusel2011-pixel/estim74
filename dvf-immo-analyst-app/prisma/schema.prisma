generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NEON_DATABASE_URL")
  directUrl = env("NEON_DATABASE_URL")
}

model Analysis {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Propriété analysée
  address     String?
  postalCode  String?
  city        String?
  lat         Float?
  lng         Float?
  communeCode String?
  irisCode    String?

  propertyType PropertyType
  surface      Float
  rooms        Int?
  bedrooms     Int?
  floor        Int?
  totalFloors  Int?
  landSurface  Float?
  yearBuilt    Int?
  condition    Condition   @default(AVERAGE)

  // Energie
  dpeLetter    String?
  gheGrade     String?

  // Options
  hasParking   Boolean @default(false)
  hasGarage    Boolean @default(false)
  hasBalcony   Boolean @default(false)
  hasTerrace   Boolean @default(false)
  hasCellar    Boolean @default(false)
  hasPool      Boolean @default(false)
  hasElevator  Boolean @default(false)
  orientation  String?
  view         String?
  mitoyennete  String?

  // Valuation result
  valuationLow    Float?
  valuationMid    Float?
  valuationHigh   Float?
  valuationPsm    Float?
  confidence      Float?
  confidenceLabel String?

  // Destinataire de l'avis de valeur
  clientFirstName String?
  clientLastName  String?
  clientAddress   String?
  clientEmail     String?
  clientPhone     String?

  // Géocodage
  geoScore      Float?
  geoQuality    String?

  // Données cadastrales IGN (parcelle)
  cadastralRef     String?
  cadastralSection String?
  cadastralNumber  String?

  // Contexte marché
  dvfSampleSize      Int?
  dvfMedianPsm       Float?
  dvfPeriodMonths    Int?
  perimeterKm        Float?
  requestedRadiusKm  Float?

  // Données JSON sérialisées
  dvfComparables  Json?
  dvfStats        Json?
  listings        Json?
  gptOutputs      Json?
  adjustments     Json?
  marketReading   Json?

  status      AnalysisStatus @default(DRAFT)
  notes       String?
  gptPayload  String?

  @@index([postalCode])
  @@index([propertyType])
  @@index([createdAt])
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
}

enum Condition {
  TO_RENOVATE
  AVERAGE
  GOOD
  EXCELLENT
}

enum AnalysisStatus {
  DRAFT
  COMPLETE
  ARCHIVED
}

model DvfMutation {
  id                        String  @id @default(cuid())
  id_mutation               String
  date_mutation             String
  nature_mutation           String
  valeur_fonciere           Float
  adresse_numero            String?
  adresse_nom_voie          String?
  code_postal               String?
  nom_commune               String
  code_commune              String
  code_departement          String
  id_parcelle               String?
  type_local                String?
  surface_reelle_bati       Float?
  lot1_surface_carrez       Float?
  nombre_pieces_principales Float?
  surface_terrain           Float?
  lat                       Float?
  lon                       Float?

  @@index([code_commune])
  @@index([code_postal])
  @@index([nature_mutation])
  @@index([type_local])
  @@index([date_mutation])
  @@index([lat, lon])
}

model ActiveListing {
  id          String    @id @default(cuid())
  uniqueId    String    @unique
  title       String?
  city        String?
  postalCode  String?
  price       Float?
  pricePsm    Float?
  surface     Float?
  rooms       Int?
  category    String?
  lat         Float?
  lng         Float?
  url         String?
  pictureUrl  String?
  energyGrade String?
  options     Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([postalCode])
  @@index([category])
  @@index([isActive])
  @@index([postalCode, category, isActive])
}
